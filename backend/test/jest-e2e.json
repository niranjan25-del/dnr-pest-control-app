{
  "$schema": "https://json.schemastore.org/jest.json",
  "preset": "ts-jest",
  "testEnvironment": "node",
  "rootDir": "..",
  "roots": ["<rootDir>/test/e2e"],
  "testRegex": "test/e2e/.*\\.e2e-spec\\.ts$",
  "moduleNameMapper": { "^src/(.*)$": "<rootDir>/src/$1" },
  "setupFilesAfterEnv": ["<rootDir>/test/support/setup-e2e.ts"],
  "testTimeout": 30000,
  "maxWorkers": 1
}
