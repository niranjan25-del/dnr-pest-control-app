# ──────────────────────────────────────────────────────────────────────────
# DNR Pest Control — Backend environment (.env.example)
# Local dev: copy to `.env`. Staging/prod: inject via AWS Secrets Manager / SSM
# (never ship .env files to the cloud). All values are validated at boot
# (src/config/env.validation.ts) — the app refuses to start if any are invalid.
# ──────────────────────────────────────────────────────────────────────────

# --- Application ---
NODE_ENV=development              # development | test | production
PORT=3000
API_PREFIX=api
API_VERSION=1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=120                # default requests/window/IP (auth & payments stricter per-route)
LOG_LEVEL=debug                   # fatal|error|warn|info|debug|trace

# --- Database (PostgreSQL / Prisma) ---
DATABASE_URL=postgresql://dnr:dnr@localhost:5432/dnr_dev?schema=public

# --- JWT ---
JWT_ACCESS_SECRET=replace-with-strong-random-secret
JWT_REFRESH_SECRET=replace-with-different-strong-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
JWT_ISSUER=dnr-pest-control
JWT_AUDIENCE=dnr-clients

# --- Firebase (Admin SDK service account) ---
FIREBASE_PROJECT_ID=replace-me
FIREBASE_CLIENT_EMAIL=replace-me@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- AWS / S3 ---
AWS_REGION=ap-south-1
AWS_S3_MEDIA_BUCKET=dnr-media-dev
AWS_CLOUDFRONT_DOMAIN=
# Local tooling only — in cloud use IAM task roles, NOT static keys:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Cashfree PG (get from merchant.cashfree.com → Settings → API Keys) ---
CASHFREE_CLIENT_ID=your-cashfree-client-id
CASHFREE_CLIENT_SECRET=your-cashfree-client-secret
CASHFREE_WEBHOOK_SECRET=your-cashfree-webhook-secret
CASHFREE_ENVIRONMENT=sandbox          # sandbox | production

# --- Firebase Cloud Messaging (uses the Admin SDK creds above) ---
FCM_ENABLED=false

# --- Google Maps (Geocoding) ---
# Optional: if unset, address geocoding is skipped and client-supplied coordinates are used.
GOOGLE_MAPS_API_KEY=
